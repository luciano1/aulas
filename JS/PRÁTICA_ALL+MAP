CÓDIGO BASE

```jsx
function App() {
  // Dados estáticos
  const nome = "Ana Clara";
  const curso = "React JS";
  const cidade = "Montes Claros";

  return (
    <div>
      {/* Header */}
      <div>
        <h1>Sistema de Alunos</h1>
        <hr />
      </div>

      {/* Perfil do aluno */}
      <div>
        <h2>{nome}</h2>

        <p>Curso: {curso}</p>

        <p>Cidade: {cidade}</p>

        <hr />
      </div>

      {/* Rodapé */}
      <div>
        <p>Projeto desenvolvido na aula de React.</p>
      </div>
    </div>
  );
}

export default App;
```

